# Build output
**/[Bb]in/
**/[Oo]bj/

# Visual Studio / Rider / VS Code user files
.vs/
.idea/
.vscode/.vs/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# Test and coverage output
TestResults/
coverage/
*.coverage
*.coveragexml
coverage.cobertura.xml

# Logs and temporary files
logs/
*.log
*.tmp
*.temp
*.cache
*.bak
*.swp
~$*

# Local SQLite database files
src/SecureFileCloud.API/AppData/Database/*.db
src/SecureFileCloud.API/AppData/Database/*.db-*
src/SecureFileCloud.API/AppData/Database/*.sqlite
src/SecureFileCloud.API/AppData/Database/*.sqlite3
!src/SecureFileCloud.API/AppData/Database/.gitkeep

# Local uploaded files
src/SecureFileCloud.API/AppData/FileStorage/*
!src/SecureFileCloud.API/AppData/FileStorage/.gitkeep

# Locally generated archives
*.zip
